{
  "mcpServers": {
    "imap-stream": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "./imap-stream-mcp",
        "run",
        "imap-stream"
      ],
      "env": {}
    },
    "codex-cli": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@cexll/codex-mcp-server"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}